rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // ARTISANS — only the artisan themselves can write their own profile,
    // but any authenticated user can read artisan profiles (needed for
    // showing seller info on product pages).
    // =====================================================================
    match /artisans/{artisanId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == artisanId;
    }

    // =====================================================================
    // PRODUCTS — any authenticated user can READ all products (marketplace).
    // Only the owning artisan can create / update / delete their products.
    // =====================================================================
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.artisanId == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.artisanId == request.auth.uid;
    }

    // =====================================================================
    // ORDERS — a customer can create an order for themselves.
    //          The artisan whose products were ordered can read the orders.
    //          The customer can read their own orders.
    // =====================================================================
    match /orders/{orderId} {
      allow read: if request.auth != null
                  && (resource.data.customerId == request.auth.uid
                      || resource.data.artisanId == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.customerId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.artisanId == request.auth.uid;
      allow delete: if false;
    }
  }
}
